---
import SEO from '../components/SEO.astro';
import type { SEOProps } from '../utils/seo';
import '../styles/global.css';

interface Props {
  seo: SEOProps;
}

const { seo } = Astro.props;
---

<!DOCTYPE html>
<html lang={seo.language || 'en'} data-wf-page="6577019a915bb98abc733643">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <SEO seo={seo} />
    
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin="anonymous" />
  </head>
  <body>
    <!-- Skip to content for accessibility -->
    <a href="#main-content" style="position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden;" onfocus="this.style.position='static'; this.style.width='auto'; this.style.height='auto'; this.style.padding='10px'; this.style.background='#fff';" onblur="this.style.position='absolute'; this.style.left='-9999px'; this.style.width='1px'; this.style.height='1px';">
      Skip to content
    </a>

    <div class="header">
      <div class="w-layout-blockcontainer main-container w-container">
        <div data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="header-inner w-nav">
          <a href="/" class="logo w-inline-block"><img src="/images/logo.png" alt="Frenzy Logo" class="logo-img" /></a>
          <nav role="navigation" class="main-menu w-nav-menu">
            <a href="/" class="menu-item w-nav-link">Home</a>
            <a href="/about" class="menu-item w-nav-link">About</a>
            <a href="/categories" class="menu-item w-nav-link">categories</a>
            <a href="/blog" class="menu-item w-nav-link">posts</a>
            <a href="/contact" class="menu-item w-nav-link">contact</a>
          </nav>
          <div class="menu-button w-nav-button" aria-label="Toggle menu" role="button" tabindex="0">
            <div class="icon w-icon-nav-menu"></div>
          </div>

          <div class="header-right-side">
            <form action="/blog" method="GET" class="search-div w-form">
              <input class="search-field w-input" maxlength="256" name="q" placeholder="type something" type="search" id="search" required="" />
              <input type="submit" class="search-button w-button" value="Search" />
              <img src="/images/search.png" alt="Search icon" class="image" />
            </form>
          </div>
        </div>
      </div>
    </div>

    <main id="main-content">
      <slot />
    </main>

    <div class="footer">
      <div class="inner-footer">
        <div class="w-layout-blockcontainer main-container w-container">
          <div id="frenzy100" class="w-layout-layout footer-grid wf-layout-layout">
            <div id="frenzy107" class="w-layout-cell footer-grid-item">
              <h4 class="footer-heading">contact</h4>
              <a href="mailto:hello@frenzy.webflow.io?subject=Your%20Mail" class="footer-email-and-phone w-inline-block">
                <img src="/images/email.png" alt="Email icon" class="footer-emailphone-icon" />
                <div class="text-block">hello@frenzy.webflow.io</div>
              </a>
              <a href="tel:+51234567890" class="footer-email-and-phone last-phone w-inline-block">
                <img src="/images/phone.png" alt="Phone icon" class="footer-emailphone-icon" />
                <div class="text-block">+5 (123) 456 789 0</div>
              </a>
            </div>

            <div id="frenzy108" class="w-layout-cell footer-grid-item">
              <h4 class="footer-heading">socials</h4>
              <div class="foot-socials">
                <a href="http://www.facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link w-inline-block"><img src="/images/fb.png" alt="Facebook logo" class="foot-social-link" /></a>
                <a href="http://www.twitter.com" target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="social-link w-inline-block"><img src="/images/twitter.png" alt="Twitter logo" class="foot-social-link" /></a>
                <a id="frenzy106" href="http://www.instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link w-inline-block">
                  <img src="/images/insta.png" alt="Instagram logo" class="foot-social-link" />
                </a>
                <a href="http://www.youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-link w-inline-block"><img src="/images/you.png" alt="YouTube logo" class="foot-social-link" /></a>
                <a href="http://www.pinterest.com" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="social-link w-inline-block"><img src="/images/pint.png" alt="Pinterest logo" class="foot-social-link" /></a>
              </div>
            </div>

            <div id="frenzy109" class="w-layout-cell footer-grid-item">
              <h4 class="footer-heading">Newsletter</h4>
              <p class="footer-text">Stay ahead of the curve with our exclusive daily newsletter directly in your inbox!</p>
              <div class="w-form">
                <form id="email-form" method="post" action="#" aria-label="Newsletter Form" class="form">
                  <input class="subscribe-field w-input" maxlength="256" name="email" placeholder="your e-mail" type="email" id="email" required="" />
                  <input type="submit" value="subscribe" class="submit-button w-button" />
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="w-layout-blockcontainer main-container w-container">
        <div class="copyright">
          <div class="copyright-text">© 2024 Frenzy - HTML Template. Made by <a href="#" class="copyright-text">Max Themes</a></div>
        </div>
      </div>
    </div>

    <!-- Webflow scripts / UI behaviors from plugins.js & jquery loaded as non-blocking -->
    <script is:inline src="/js/jquery.min.js" defer></script>
    <script is:inline src="/js/plugins.js" defer></script>
    <script is:inline src="/js/webfont.js" defer></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof WebFont !== 'undefined') {
          WebFont.load({ google: { families: ["Manrope:200,300,regular,500,600,700,800"] } });
        }
        
        // Basic menu toggling for mobile menus inside standard Webflow structure
        if (typeof $ !== 'undefined') {
          $('.menu-button').on('click', function() {
            $('.main-menu').toggleClass('w--open');
          });
        }
      });
    </script>
  </body>
</html>
