---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = Array.from(new Set(allPosts.flatMap(post => post.data.tags || [])));
  
  return tags.map(tag => {
    const posts = allPosts.filter(post => post.data.tags.some(t => t.toLowerCase() === tag.toLowerCase()));
    return {
      params: { slug: tag.toLowerCase() },
      props: { tagName: tag, posts }
    };
  });
}

const { tagName, posts } = Astro.props;
---

<Layout seo={{ title: `Tag: ${tagName} Articles - Frenzy`, description: `Browse all articles tagged with ${tagName}.` }}>
  <div class="main-content">
    <div class="main-container">
      <div class="w-row">
        <div class="column w-col w-col-8 w-col-stack">
          <div class="single-post-body" style="padding: 20px;">
            <h2 class="signle-post-title" style="font-size: 2rem; margin-bottom: 24px; text-transform: capitalize;">Tag: #{tagName}</h2>
            
            <div class="blog-list-wrapper w-dyn-list">
              <div role="list" class="blog-list w-dyn-items" style="display: flex; flex-direction: column; gap: 30px;">
                {posts.map(post => (
                  <div role="listitem" class="w-dyn-item">
                    <a href={`/blog/${post.slug}`} class="blog-list-item w-inline-block" style="display: flex; gap: 20px; align-items: center; text-decoration: none; color: inherit;">
                      <img alt={post.data.title} src={post.data.featuredImage} class="blog-main-image" style="width: 200px; height: 120px; object-fit: cover; border-radius: 4px;" />
                      <div style="flex: 1;">
                        <div style="font-size: 0.85rem; text-transform: uppercase; font-weight: bold; color: #555;">{post.data.category}</div>
                        <h4 class="main-blog-title" style="margin-top: 4px; margin-bottom: 8px; font-size: 1.25rem;">{post.data.title}</h4>
                        <p style="font-size: 0.9rem; color: #666; margin: 0;">{post.data.description}</p>
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
        <div class="column w-col w-col-4 w-col-stack">
          <Sidebar />
        </div>
      </div>
    </div>
  </div>
</Layout>
