---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());

// Get search query from URL (e.g., /blog?q=something)
// Since this is static output, we can support client-side filtering via script below.
---

<Layout seo={{ title: "Frenzy Blog - All Posts", description: "Search and browse all frenzy articles and news posts." }}>
  <div class="main-content">
    <div class="main-container">
      <div class="w-row">
        <div class="column w-col w-col-8 w-col-stack">
          <div class="single-post-body" style="padding: 20px;">
            <h2 class="signle-post-title" style="font-size: 2rem; margin-bottom: 24px;">All Blog Posts</h2>
            
            <!-- Live Search Bar -->
            <div style="margin-bottom: 30px;">
              <input type="text" id="live-search-input" placeholder="Search by title, description or category..." style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem;" />
            </div>

            <div id="posts-list-container" class="blog-list-wrapper w-dyn-list">
              <div role="list" class="blog-list w-dyn-items" style="display: flex; flex-direction: column; gap: 30px;">
                {sortedPosts.map(post => (
                  <div role="listitem" class="w-dyn-item post-search-card" data-title={post.data.title.toLowerCase()} data-description={post.data.description.toLowerCase()} data-category={post.data.category.toLowerCase()}>
                    <a href={`/blog/${post.slug}`} class="blog-list-item w-inline-block" style="display: flex; gap: 20px; align-items: center; text-decoration: none; color: inherit;">
                      <img alt={post.data.title} src={post.data.featuredImage} class="blog-main-image" style="width: 200px; height: 120px; object-fit: cover; border-radius: 4px;" />
                      <div style="flex: 1;">
                        <div style="font-size: 0.85rem; text-transform: uppercase; font-weight: bold; color: #555;">{post.data.category}</div>
                        <h4 class="main-blog-title" style="margin-top: 4px; margin-bottom: 8px; font-size: 1.25rem;">{post.data.title}</h4>
                        <p style="font-size: 0.9rem; color: #666; margin: 0;">{post.data.description}</p>
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            </div>
            
            <div id="no-results-message" style="display: none; padding: 40px text-align: center; color: #666;">
              No posts matched your search criteria.
            </div>
          </div>
        </div>
        <div class="column w-col w-col-4 w-col-stack">
          <Sidebar />
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Live Search Logic
    const searchInput = document.getElementById('live-search-input');
    const postCards = document.querySelectorAll('.post-search-card');
    const noResults = document.getElementById('no-results-message');

    // Populate search query if present in URL
    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get('q');
    if (initialQuery) {
      searchInput.value = initialQuery;
      filterPosts(initialQuery.toLowerCase());
    }

    searchInput.addEventListener('input', (e) => {
      filterPosts(e.target.value.toLowerCase());
    });

    function filterPosts(query) {
      let matchedCount = 0;
      postCards.forEach(card => {
        const title = card.getAttribute('data-title');
        const desc = card.getAttribute('data-description');
        const cat = card.getAttribute('data-category');

        if (title.includes(query) || desc.includes(query) || cat.includes(query)) {
          card.style.display = 'block';
          matchedCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (matchedCount === 0) {
        noResults.style.display = 'block';
      } else {
        noResults.style.display = 'none';
      }
    }
  </script>
</Layout>
